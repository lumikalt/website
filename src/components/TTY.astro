---
// Import all .txt files at build time
const files = import.meta.glob("/src/content/files/*.txt", {
  query: "?raw",
  import: "default",
  eager: true
});

// Build a map: { "about.txt": "content...", "contacts.txt": "content..." }
const fileMap: Record<string, string> = {};
for (const [path, content] of Object.entries(files)) {
  const filename = path.split("/").pop()!;
  fileMap[filename] = content as string;
}

interface Props {
  welcomeText: string;
  baudRate?: number;
}

const { welcomeText, baudRate = 120 } = Astro.props;
---

<div class="tty-container">
  <div class="paper" id="paper">
    <div class="paper-content" id="output"></div>
    <div class="input-line" id="input-line" style="display: none;">
      <span class="prompt">&gt;&nbsp;</span>
      <input
        type="text"
        id="command-input"
        autocomplete="off"
        spellcheck="false"
      />
    </div>
  </div>
</div>

<script
  is:inline
  define:vars={{
    welcomeText,
    baudRate,
    fileMap,
    charDelay: (8 / baudRate) * 1000
  }}
>
  class TTYSounds {
    constructor() {
      this.sounds = {};
      this.enabled = true;
      this.loaded = false;
    }

    async load() {
      const soundFiles = {
        key: "/sounds/down-key-01.wav",
        print: "/sounds/down-key-02.wav",
        space: "/sounds/down-key-03.wav",
        cr: "/sounds/down-cr-01.wav",
        bell: "/sounds/down-bell.wav"
      };

      for (const [name, path] of Object.entries(soundFiles)) {
        try {
          this.sounds[name] = new Audio(path);
          this.sounds[name].preload = "auto";
        } catch (e) {
          console.warn(`Could not load sound: ${name}`);
        }
      }
      this.loaded = true;
    }

    play(name) {
      if (!this.enabled || !this.loaded) return;
      const sound = this.sounds[name];
      if (sound) {
        const clone = sound.cloneNode();
        clone.volume = 0.5;
        clone.play().catch(() => {});
      }
    }
  }

  const ttySound = new TTYSounds();
  const output = document.getElementById("output");
  const inputLine = document.getElementById("input-line");
  const commandInput = document.getElementById("command-input");
  const paper = document.getElementById("paper");

  async function teletype(text, speed = charDelay) {
    for (const char of text) {
      output.textContent += char;
      paper.scrollTop = paper.scrollHeight;

      // Play appropriate sound
      if (char === "\n" || char === "\r") {
        ttySound.play("cr");
      } else if (char === " ") {
        ttySound.play("space");
      } else {
        ttySound.play("print");
      }

      await new Promise(r => setTimeout(r, speed));
    }
  }

  // Print instantly (for command output)
  function print(text) {
    output.textContent += text;
    paper.scrollTop = paper.scrollHeight;
  }

  // Available commands
  const commands = {
    help: () => {
      return `
AVAILABLE COMMANDS:
  cat <file>  - Display file contents
  ls          - List available files
  help        - Show this message
  mute        - Mute the sound effects

AVAILABLE FILES:
  ${Object.keys(fileMap).join("\n  ")}
`;
    },

    ls: () => {
      return "\n" + Object.keys(fileMap).join("\n") + "\n";
    },

    cat: args => {
      const filename = args[0];
      if (!filename) {
        return "\nERROR: Usage: cat <filename>\n";
      }
      if (fileMap[filename]) {
        return "\n" + fileMap[filename] + "\n";
      }
      return `\nERROR: File not found: ${filename}\n`;
    },

    mute: () => {
      ttySound.enabled = !ttySound.enabled;
      return `\nSound ${ttySound.enabled ? "enabled" : "disabled"}.\n`;
    }
  };

  // Process command
  async function processCommand(input) {
    const parts = input.trim().split(/\s+/);
    const cmd = parts[0]?.toLowerCase();
    const args = parts.slice(1);

    print(`\n> ${input}\n`);

    if (!cmd) return;

    if (commands[cmd]) {
      const result = commands[cmd](args);
      await teletype(result);
    } else {
      await teletype(
        `\nERROR: Unknown command: ${cmd}\nType 'help' for available commands.\n`
      );
    }
    ttySound.play("bell")
  }

  // Initialize
  async function init() {
    const startAudio = async () => {
      await ttySound.load();
      document.removeEventListener("click", startAudio);
      document.removeEventListener("keydown", startAudio);
    };
    document.addEventListener("click", startAudio, { once: true });
    document.addEventListener("keydown", startAudio, { once: true });

    // Type out welcome message
    await teletype(welcomeText);
    await teletype('\n\nType "help" for available commands.\n\n');

    // Show input line
    inputLine.style.display = "flex";
    commandInput.focus();
    ttySound.play("bell")
  }

  commandInput.addEventListener("keydown", e => {
    if (e.key.length === 1 || e.key === "Backspace") {
      ttySound.play("key");
    }
  });

  // Handle input
  commandInput.addEventListener("keydown", async e => {
    if (e.key === "Enter") {
      const value = commandInput.value;
      commandInput.value = "";
      inputLine.style.display = "none";
      await processCommand(value);
      inputLine.style.display = "flex";
      commandInput.focus();
    }
  });

  // Keep focus on input when clicking paper
  paper.addEventListener("click", () => {
    commandInput.focus();
  });

  init();
</script>

<style>
  .tty-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* Paper starts at bottom */
    background: #2a2a2a;
    padding: 20px;
  }

  .paper {
    background: 
    /* Perforation holes on the left */ repeating-linear-gradient(
        to bottom,
        transparent 0px,
        transparent 14px,
        #ccc 14px,
        #ccc 18px,
        transparent 18px,
        transparent 20px
      ),
      /* Paper color */ linear-gradient(to bottom, #f4f1e4 0%, #f9f6e9 100%);
    background-size: 20px 100%, /* Perforation strip width */ 100% 100%; /* Paper gradient */
    background-position: left top, left top;
    background-repeat: repeat-y, repeat;

    /* Add left padding so text doesn't overlap perforations */
    padding-left: 40px;

    /* Rest of your styles */
    color: #1a1a1a;
    font-family: inherit;
    font-size: 14px;
    line-height: 1.6;
    padding-top: 40px;
    padding-right: 60px;
    padding-bottom: 40px;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.3), inset 0 0 60px rgba(0, 0, 0, 0.05);
    border-radius: 2px;
  }

  .paper-content {
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  .input-line {
    display: flex;
    align-items: center;
    margin-top: 10px;
  }

  .prompt {
    color: #1a1a1a;
    font-weight: bold;
  }

  #command-input {
    background: #fff5;
    border: none;
    outline: none;
    font-family: inherit;
    font-size: inherit;
    color: inherit;
    flex: 1;
    caret-color: #1a1a1a;
  }

  /* Hide scrollbar but keep functionality */
  .paper::-webkit-scrollbar {
    width: 8px;
  }
  .paper::-webkit-scrollbar-track {
    background: #e0ddd0;
  }
  .paper::-webkit-scrollbar-thumb {
    background: #888;
    border-radius: 4px;
  }
</style>
